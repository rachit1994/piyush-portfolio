{
  "name": "piyush-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "PAGES_BASE_PATH=/piyush-portfolio next build",
    "preview": "serve out",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:export": "node scripts/verify-export.mjs",
    "verify:pages": "PAGES_BASE_PATH=/piyush-portfolio npm run verify:export",
    "media:optimize": "node scripts/optimize-media.mjs",
    "perf:memory": "node scripts/measure-memory.mjs",
    "perf:lighthouse": "lhci autorun",
    "perf": "npm run build && npm run perf:memory && npm run perf:lighthouse",
    "postinstall": "patch-package",
    "architecture:check": "node scripts/verify-architecture.mjs",
    "check": "npm run format:check && npm run architecture:check && npm run lint && npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "npm@11.12.1",
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  },
  "dependencies": {
    "@fontsource/dm-sans": "5.2.8",
    "@fontsource/instrument-serif": "5.2.8",
    "@supabase/supabase-js": "2.108.2",
    "embla-carousel-auto-scroll": "8.6.0",
    "embla-carousel-react": "8.6.0",
    "embla-carousel-wheel-gestures": "8.1.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recoil": "0.7.7"
  },
  "devDependencies": {
    "@lhci/cli": "0.15.1",
    "@tailwindcss/postcss": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "patch-package": "8.0.1",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "puppeteer": "25.2.0",
    "serve": "14.2.6",
    "sharp": "0.35.2",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
