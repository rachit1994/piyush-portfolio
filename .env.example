# Public — inlined into the client bundle at build time.
# Safe to expose ONLY because Supabase Row Level Security is enabled.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Cloudflare-proxied media domain (NOT *.pages.dev) used for /cdn-cgi/image/.
NEXT_PUBLIC_MEDIA_BASE_URL="https://media.your-domain.com"

# Server-only — set as Cloudflare Pages Function secrets. NEVER expose these.
SUPABASE_JWKS_URL="https://your-project.supabase.co/auth/v1/.well-known/jwks.json"
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="portfolio-media"
# Optional — contact-form notifications.
RESEND_API_KEY=""
